<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN"
    "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">
<head>
  <title><%= site.name %> <%= site.tagline %></title>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="robots" content="index, follow"/>
  <meta name="description" content="<%= site.name %> <%= site.tagline %>."/>

  <link rel="icon" href="images/favicon.png" type="image/png"/>
  <link rel="shortcut icon" href="favicon.ico"/>
  <link rel="stylesheet" href="css/electrum.css" type="text/css" media="screen" />
  <link rel="stylesheet" href="css/sprites.css" type="text/css" media="screen" />
  <link rel="stylesheet" href="css/prettyPhoto.css" type="text/css" media="screen" />
  <link rel="stylesheet" href="css/electrin-overrides.css" type="text/css" media="screen" />

  <script type="text/javascript" src="js/jquery-1.7.1.min.js"></script>
  <script type="text/javascript" src="js/jquery.scrollTo-1.4.2-min.js"></script>
  <script type="text/javascript" src="js/jquery.prettyPhoto.js"></script>
  <script type="text/javascript" src="js/jquery.cycle.lite.js"></script>
  <script type="text/javascript" src="js/jquery.client.js"></script>
  <script type="text/javascript" src="js/jquery.socialbutton-1.8.0.js"></script>
  <script type="text/javascript" src="js/qrcode.js"></script>
</head>
<body>
  <header class="topbar">
    <div id="header">
      <div class="wrapper">
        <div id="logo">
          <a href="#home" onclick="location.hash='#home'; window.scrollTo(0,0); return false;">
            <div id="electrum_logo"><img src="logo/electrum_logo.png" alt="<%= site.name %>" border="none" width="70" align="top"/></div>
            <div id="electrum_text"></div>
            <span id="logo_subtitle"><%= site.tagline %></span>
          </a>
        </div>
        <div style="float:right">
          <div id="social-icons">
            <a href="<%= site.githubUrl %>" class="icon-github"></a>
            <% if (site.xUrl && site.xUrl !== 'https://x.com/') { %>
              <a href="<%= site.xUrl %>" class="icon-twitter"></a>
            <% } %>
          </div>
          <div class="clear"></div>
          <div id="menu">
            <ul class="navigation">
              <li><a href="#home" onclick="location.hash='#home'; window.scrollTo(0,0); return false;">Home</a></li>
              <li><a href="#download" onclick="location.hash='#download'; window.scrollTo(0,0); return false;">Download</a></li>
              <li><a href="#community" onclick="location.hash='#community'; window.scrollTo(0,0); return false;">Community</a></li>
              <li><a href="#about" onclick="location.hash='#about'; window.scrollTo(0,0); return false;">About</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </header>

  <div id="content">
    <div class="wrapper">
      <p><%= site.warning %></p>

      <div class="page" id="download">
        <h2>Latest release: <%= site.name %>-<%= site.latestVersion %> <span class="hl">(Release Candidate)</span></h2>

        <a href="<%= site.releaseNotesUrl %>">Release notes</a> -
        <a href="<%= site.previousReleasesUrl %>">Previous releases</a><br/>

        <div style="font-size:small">
            Testing release only. Use at your own risk, keep backups of your seed phrase and wallet files, and do not use as your primary wallet yet.<br/>
            <strong><%= site.latestVersion %></strong> is a testing release candidate and not a final stable release.<br/>
        </div>

        <% const windows = downloads.find(group => group.platform === 'Windows'); %>
        <% const linux = downloads.find(group => group.platform === 'Linux'); %>
        <% const android = downloads.find(group => group.platform === 'Android'); %>

        <h3>Sources and Binaries</h3>
        <table class="downloads">
          <tr>
            <td>
              <img src="icons/tar-gz.png" width="32"/> Source
            </td>
            <td>
              <a href="<%= linux && linux.items[1] ? linux.items[1].url : '#' %>"><%= site.name %>-<%= site.latestVersion %>.tar.gz</a>
            </td>
            <td>
              <span style="font-size:80%">Testing users and packagers</span>
            </td>
          </tr>
          <tr>
            <td>
              <img src="icons/os_linux.gif" class="os-linux"/> Linux
            </td>
            <td>
              <a href="<%= linux && linux.items[0] ? linux.items[0].url : '#' %>">AppImage</a>
              <span style="font-size:80%">(x86_64)</span>
            </td>
            <td>
              <span style="font-size:80%">Recommended for most Linux users</span>
            </td>
          </tr>
          <tr>
            <td rowspan="3">
              <img src="icons/os_windows.gif"/> Windows
            </td>
            <td>
              <a href="<%= windows && windows.items[0] ? windows.items[0].url : '#' %>">Windows Installer</a>
            </td>
            <td>
              <span style="font-size:80%">Recommended for most users</span>
            </td>
          </tr>
          <tr>
            <td>
              <a href="<%= windows && windows.items[1] ? windows.items[1].url : '#' %>">Portable version</a>
            </td>
            <td>
              <span style="font-size:80%">USB/folder-based setup</span>
            </td>
          </tr>
          <tr>
            <td>
              <a href="<%= windows && windows.items[2] ? windows.items[2].url : '#' %>">Standalone executable</a>
            </td>
            <td>
              <span style="font-size:80%">For experienced users</span>
            </td>
          </tr>
          <tr>
            <td>
              <img src="icons/android_icon.png" width="30"/> Android
              <span style="font-size:80%">(arm64-v8a)</span>
            </td>
            <td>
              <a href="<%= android && android.items[0] ? android.items[0].url : '#' %>">APK download</a>
            </td>
            <td>
              <span style="font-size:80%">Manual install for testers</span>
            </td>
          </tr>
        </table>

        <h3>Latest News</h3>
        <div class="downloads" style="padding:5px">
          <% news.forEach((item) => { %>
            <p>
              <strong><%= item.date %></strong> —
              <a href="<%= item.url %>"><%= item.title %></a><br/>
              <%= item.summary %>
            </p>
          <% }) %>
        </div>
      </div>

      <div class="page" id="community">
        <% const community = site.community || {}; %>
        <h2><%= community.title || 'Community Links' %></h2>

        <% if (community.sections && community.sections.length > 0) { %>
          <% community.sections.forEach((section) => { %>
            <h4><%= section.heading %></h4>
            <ul>
              <% (section.items || []).forEach((item) => { %>
                <li>
                  <strong><%= item.label %></strong>:
                  <% if (item.url) { %>
                    <a href="<%= item.url %>"><%= item.urlLabel || item.url %></a>
                  <% } else if (item.codes && item.codes.length > 0) { %>
                    <% item.codes.forEach((codeValue, codeIndex) => { %>
                      <code><%= codeValue %></code><%= codeIndex < item.codes.length - 1 ? ', ' : '' %>
                    <% }) %>
                  <% } else if (item.value) { %>
                    <%= item.value %>
                  <% } %>
                  <% if (item.description) { %>
                    <div style="font-size:80%"><%= item.description %></div>
                  <% } %>
                </li>
              <% }) %>
            </ul>
          <% }) %>
        <% } %>
      </div>

      <div class="page" id="about">
        <% const aboutPage = site.aboutPage || {}; %>
        <% if (aboutPage.title) { %><h2><%= aboutPage.title %></h2><% } %>

        <% if (aboutPage.sections && aboutPage.sections.length > 0) { %>
          <% aboutPage.sections.forEach((section) => { %>
            <h4><%= section.heading %></h4>
            <% (section.paragraphs || []).forEach((paragraph) => { %>
              <p><%= paragraph %></p>
            <% }) %>
          <% }) %>
        <% } else { %>
          <h4>About <%= site.name %></h4>
          <p><%= site.about %></p>

          <h4>Project status</h4>
          <p>
            <%= site.name %> <%= site.latestVersion %> is currently a release candidate build intended for wider testing before a stable release.
          </p>

          <h4>Disclaimer</h4>
          <p><%= site.disclaimer %></p>
        <% } %>
      </div>

      <div class="page default" id="home">
        <div id="slides" class="slideshow"></div>

        <div class="clear"></div>
        <div class="featured-space"></div>

        <div class="clear"></div>

        <div class="features">
          <% site.features.forEach(function(feature, i) { %>
            <div class="feature-item<%= (i + 1) % 3 === 0 ? ' last' : '' %>">
              <h2 class="icon icon-<%= feature.icon %>"><%= feature.title %></h2>
              <p><%= feature.text %></p>
            </div>
            <% if ((i + 1) % 3 === 0 && i + 1 < site.features.length) { %><div class="clear"></div><% } %>
          <% }) %>
          <div class="clear"></div>
        </div>

        <div style="clear: both;"></div>
        <br/>

        <p style="text-align:center;">
          <a href="#download" class="button">Download <%= site.name %></a>
        </p>
      </div>
    </div>
  </div>

  <div id="footer">
    <div class="wrapper">
      <div class="col1">
        <p><a href="#about" onclick="location.hash='#about'; window.scrollTo(0,0); return false;">About</a></p>
        <p><a href="#community" onclick="location.hash='#community'; window.scrollTo(0,0); return false;">Community</a></p>
      </div>
      <div class="col2">
        <p>Released under the <a href="<%= site.licenseUrl %>">MIT Licence</a></p>
        <p><a href="<%= site.sourceUrl %>">Website source</a></p>
      </div>
    </div>
    <div class="clear"></div>
  </div>

  <script type="text/javascript" charset="utf-8">
    var SLIDES = <%- JSON.stringify(site.slides || []) %>;
    $(document).ready(function(){
      $(SLIDES).each(function (index, element) {
        var link_html = element.link ? "<a href='" + element.link + "'>More information</a>" : '';
        var html = [
          '<div class="caption"><h3>', element.title, '</h3>',
          '<p>', element.description, '</p>',
          link_html,
          '</div>',
          '<img src="slides/', element.id, '.png" alt="', element.title, '"/>'
        ].join('');
        var item = $('<div></div>').html(html);
        $('#slides').append(item);
      });

      $("a[rel^='prettyPhoto']").prettyPhoto({
        overlay_gallery: false,
        deeplinking: false
      });

      if (SLIDES.length > 1) {
        $(".slideshow").cycle({
          timeout: 8000,
          speed: 1000
        });
      }
    });
  </script>
</body>
</html>
